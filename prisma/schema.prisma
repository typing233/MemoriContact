generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  password      String
  emailReminder Boolean        @default(false)
  createdAt     DateTime       @default(now())
  contacts      Contact[]
  notifications Notification[]
}

model Contact {
  id               String          @id @default(cuid())
  userId           String
  name             String
  avatar           String?
  notes            String?
  contactFrequency Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags             Tag[]
  customFields     CustomField[]
  interactions     Interaction[]
  importantDates   ImportantDate[]
  reminders        Reminder[]

  @@index([userId])
}

model Tag {
  id        String  @id @default(cuid())
  name      String
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model CustomField {
  id        String  @id @default(cuid())
  label     String
  value     String
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model Interaction {
  id        String   @id @default(cuid())
  type      String
  note      String?
  location  String?
  date      DateTime
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([contactId])
}

model ImportantDate {
  id        String  @id @default(cuid())
  label     String
  date      String
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model Reminder {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String?
  dueDate   DateTime
  done      Boolean  @default(false)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([contactId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String?
  read      Boolean  @default(false)
  type      String
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
