generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  contacts  Contact[]
}

model Contact {
  id             String          @id @default(cuid())
  userId         String
  name           String
  avatar         String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags           Tag[]
  customFields   CustomField[]
  interactions   Interaction[]
  importantDates ImportantDate[]

  @@index([userId])
}

model Tag {
  id        String  @id @default(cuid())
  name      String
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model CustomField {
  id        String  @id @default(cuid())
  label     String
  value     String
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model Interaction {
  id        String   @id @default(cuid())
  type      String
  note      String?
  location  String?
  date      DateTime
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([contactId])
}

model ImportantDate {
  id        String  @id @default(cuid())
  label     String
  date      String
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}
